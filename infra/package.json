{
    "name": "@adaptive-streaming/infra",
    "version": "1.0.0",
    "description": "Lambda transcoder + Serverless Framework infra",
    "scripts": {
        "deploy": "npx serverless deploy --stage dev",
        "deploy:prod": "npx serverless deploy --stage prod",
        "deploy:local": "FFMPEG_PATH=$(which ffmpeg) npx serverless deploy --stage local",
        "remove": "npx serverless remove --stage dev"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.0.0"
    },
    "devDependencies": {
        "serverless": "^3.0.0",
        "serverless-localstack": "^1.0.0"
    }
}